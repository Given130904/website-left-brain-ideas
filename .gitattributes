# Normalize all text files to LF in the repo, checkout as-is on Windows
* text=auto eol=lf

# Force binary files to never be converted
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.svg text eol=lf
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.otf binary
